---
/**
 * 关于页 - 个人介绍
 *
 * URL: /about/
 *
 * Requirements: 3.1
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config';
import { t } from '../../utils/i18n';
---

<BaseLayout title={t('tabs.about')} description={`${siteConfig.title} - ${t('tabs.about')}`}>
  <div class="about-page">
    <div class="about-header">
      <img
        src={siteConfig.avatar}
        alt={siteConfig.social.name}
        class="about-avatar"
      />
      <h1 class="about-name">{siteConfig.social.name}</h1>
      <p class="about-tagline">{siteConfig.tagline}</p>
    </div>

    <div class="about-content">
      <section class="about-section">
        <h2>{siteConfig.lang === 'zh-CN' ? '关于我' : 'About Me'}</h2>
        <p>{siteConfig.description}</p>
      </section>

      <section class="about-section">
        <h2>{siteConfig.lang === 'zh-CN' ? '联系方式' : 'Contact'}</h2>
        <ul class="contact-list">
          <li>
            <strong>GitHub:</strong>
            <a href={`https://github.com/${siteConfig.social.github}`} target="_blank" rel="noopener noreferrer">
              {siteConfig.social.github}
            </a>
          </li>
          <li>
            <strong>Email:</strong>
            <a href={`mailto:${siteConfig.social.email}`}>{siteConfig.social.email}</a>
          </li>
        </ul>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    max-width: 42rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .about-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .about-avatar {
    width: 7rem;
    height: 7rem;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
    box-shadow: var(--card-shadow);
  }

  .about-name {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.375rem;
  }

  .about-tagline {
    font-size: 1rem;
    color: var(--text-secondary);
    margin: 0;
    font-style: italic;
  }

  .about-content {
    line-height: 1.75;
  }

  .about-section {
    margin-bottom: 2rem;
  }

  .about-section h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    padding-bottom: 0.375rem;
    border-bottom: 1px solid var(--border-color, #e5e5e5);
  }

  .about-section p {
    color: var(--text-secondary);
    margin: 0;
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contact-list li {
    padding: 0.375rem 0;
    color: var(--text-secondary);
  }

  .contact-list a {
    color: var(--link-color);
    text-decoration: none;
  }

  .contact-list a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .about-page {
      padding: 1rem 0.75rem;
    }

    .about-avatar {
      width: 5rem;
      height: 5rem;
    }
  }
</style>
