---
/**
 * 文章详情页
 *
 * URL: /posts/{slug}/
 * 使用 PostLayout 布局，集成 TOC、CodeCopy、PostNav、RelatedPosts、Comment
 *
 * Requirements: 2.5, 3.1, 3.3, 3.4
 */
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { sortPosts, getPostNavigation, getRelatedPosts, generateSlug, type Post } from '../../utils/posts';

export const getStaticPaths: GetStaticPaths = async () => {
  const allPosts = await getCollection('posts');
  const mapped: Post[] = allPosts.map((p) => ({
    id: p.id,
    slug: generateSlug(p.id),
    data: p.data,
    body: p.body,
  }));
  const sortedPosts = sortPosts(mapped);

  return allPosts.map((entry) => ({
    params: { slug: generateSlug(entry.id) },
    props: {
      entry,
      post: mapped.find((p) => p.id === entry.id)!,
      sortedPosts,
    },
  }));
};

const { entry, post, sortedPosts } = Astro.props;
const { Content } = await render(entry);


// Get navigation and related posts
const navigation = getPostNavigation(sortedPosts, post.slug);
const relatedPosts = getRelatedPosts(sortedPosts, post, 5);
---

<PostLayout
  title={post.data.title}
  date={post.data.date}
  categories={post.data.categories}
  tags={post.data.tags}
  description={post.data.description}
  image={post.data.image}
  lastModifiedAt={post.data.last_modified_at}
  comments={post.data.comments}
  toc={post.data.toc}
  content={post.body || ''}
  slug={post.slug}
  prev={navigation.prev}
  next={navigation.next}
  relatedPosts={relatedPosts}
>
  <Content />
</PostLayout>
