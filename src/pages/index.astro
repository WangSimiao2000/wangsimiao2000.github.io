---
import BaseLayout from '../layouts/BaseLayout.astro';
import Pagination from '../components/Pagination.astro';
import RightPanel from '../components/RightPanel.astro';
import { siteConfig } from '../config';
import { getAllPosts, sortPosts, paginatePosts, getPostUrl } from '../utils/posts';
import { formatDate } from '../utils/date';
import type { Locale } from '../types';

const locale = siteConfig.lang as Locale;
const allPosts = await getAllPosts();
const sortedPosts = sortPosts(allPosts);
const pagination = paginatePosts(sortedPosts, 1);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <div class="home-layout">
    <div class="home-main">
      <div id="post-list">
        {pagination.items.map((post) => (
          <article class="card-wrapper card">
            <a href={getPostUrl(post.slug)} class="post-preview">
              <div class="card-body d-flex flex-column">
                {post.data.pin && <span class="pin-badge"><i class="fas fa-thumbtack"></i> {t('post.pin_prompt')}</span>}
                <h1 class="card-title">{post.data.title}</h1>
                {post.data.description && (
                  <div class="card-text"><p>{post.data.description}</p></div>
                )}
                <div class="post-meta">
                  <span>
                    <i class="far fa-calendar fa-fw"></i>
                    <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date, locale)}</time>
                  </span>
                  {post.data.categories.length > 0 && (
                    <span>
                      <i class="far fa-folder-open fa-fw"></i>
                      {post.data.categories.join(', ')}
                    </span>
                  )}
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
      {pagination.items.length === 0 && <p class="no-posts">暂无文章</p>}
      <Pagination currentPage={1} totalPages={pagination.totalPages} basePath="/" />
    </div>
    <RightPanel />
  </div>
</BaseLayout>

<style>
  .home-layout {
    display: flex;
    gap: 2rem;
    max-width: 64rem;
    margin: 0 auto;
    padding: 1.5rem 1rem;
  }

  .home-main {
    flex: 1;
    min-width: 0;
  }

  #post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-wrapper {
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .post-preview {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-body {
    padding: 1.25rem 1.5rem;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .card-text {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .card-text p { margin: 0; }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-top: auto;
  }

  .post-meta i { margin-right: 0.25rem; }

  .pin-badge {
    font-size: 0.75rem;
    color: var(--btn-primary-bg);
    margin-bottom: 0.25rem;
  }

  .no-posts {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
  }

  @media (max-width: 768px) {
    .home-layout { padding: 1rem 0.75rem; }
    .card-body { padding: 1rem; }
    .card-title { font-size: 1.125rem; }
  }
</style>
