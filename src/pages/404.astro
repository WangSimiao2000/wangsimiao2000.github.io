---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
import { t } from '../utils/i18n';
---

<BaseLayout title="404" description="Page not found" noindex={true}>
  <div class="not-found">
    <h1>404</h1>
    <p>{t('not_found.statement')}</p>
    <a href="/" class="back-home">
      <i class="fas fa-home"></i>
      {t('tabs.home')}
    </a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 5rem 1rem;
  }

  .not-found h1 {
    font-size: 5rem;
    font-weight: 700;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }

  .not-found p {
    font-size: 1.125rem;
    color: var(--text-secondary);
    margin: 0 0 2rem;
  }

  .back-home {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.4rem;
    border-radius: 0.5rem;
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    text-decoration: none;
    transition: background 0.2s;
  }

  .back-home:hover { background: var(--btn-primary-hover); }
</style>
