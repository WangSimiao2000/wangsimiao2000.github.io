---
/**
 * 相册页 - 瀑布流布局 + Lightbox 预览 + 分页加载
 *
 * URL: /gallery/
 * 从 data/gallery.yml 读取数据，使用 CSS columns 实现瀑布流
 * 图片点击后通过 Lightbox 组件全屏预览
 *
 * Requirements: 3.1, 3.5, 12.2
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Lightbox from '../../components/Lightbox.astro';
import { siteConfig } from '../../config';
import { loadGallery } from '../../utils/data';
import { t } from '../../utils/i18n';

const ITEMS_PER_PAGE = 12;
const gallery = loadGallery();
const initialItems = gallery.slice(0, ITEMS_PER_PAGE);
const hasMore = gallery.length > ITEMS_PER_PAGE;
---

<BaseLayout title={t('tabs.gallery')} description={`${siteConfig.title} - ${t('tabs.gallery')}`}>
  <div class="gallery-page">
    <h1 class="page-title">{t('tabs.gallery')}</h1>

    <div class="gallery-masonry" id="gallery-grid">
      {initialItems.map((item) => (
        <div class="gallery-item">
          <img
            src={item.image}
            alt={item.title}
            loading="lazy"
            data-lightbox
            data-lightbox-src={item.image}
            data-lightbox-alt={item.title}
          />
          <div class="gallery-caption">{item.title}</div>
        </div>
      ))}
    </div>

    {hasMore && (
      <div class="gallery-load-more" id="load-more-container">
        <button id="load-more-btn" class="load-more-btn">
          {siteConfig.lang === 'zh-CN' ? '加载更多' : 'Load More'}
        </button>
      </div>
    )}
  </div>

  <Lightbox />
</BaseLayout>

<script define:vars={{ gallery, ITEMS_PER_PAGE }}>
  // Pagination state
  let currentPage = 1;

  const grid = document.getElementById('gallery-grid');
  const loadMoreBtn = document.getElementById('load-more-btn');
  const loadMoreContainer = document.getElementById('load-more-container');

  function createGalleryItem(item) {
    const div = document.createElement('div');
    div.className = 'gallery-item';

    const img = document.createElement('img');
    img.src = item.image;
    img.alt = item.title;
    img.loading = 'lazy';
    img.dataset.lightbox = '';
    img.dataset.lightboxSrc = item.image;
    img.dataset.lightboxAlt = item.title;

    // Bind lightbox click
    img.addEventListener('click', () => {
      const overlay = document.getElementById('lightbox-overlay');
      const lightboxImg = overlay?.querySelector('.lightbox-image');
      if (overlay && lightboxImg) {
        lightboxImg.src = item.image;
        lightboxImg.alt = item.title;
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });

    const caption = document.createElement('div');
    caption.className = 'gallery-caption';
    caption.textContent = item.title;

    div.appendChild(img);
    div.appendChild(caption);
    return div;
  }

  function loadMore() {
    currentPage++;
    const start = (currentPage - 1) * ITEMS_PER_PAGE;
    const end = start + ITEMS_PER_PAGE;
    const nextItems = gallery.slice(start, end);

    nextItems.forEach((item) => {
      grid?.appendChild(createGalleryItem(item));
    });

    // Hide button if no more items
    if (end >= gallery.length && loadMoreContainer) {
      loadMoreContainer.style.display = 'none';
    }
  }

  loadMoreBtn?.addEventListener('click', loadMore);
</script>

<style>
  .gallery-page {
    max-width: 60rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }

  /* Masonry / waterfall layout using CSS columns */
  .gallery-masonry {
    columns: 3;
    column-gap: 1rem;
  }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: 1rem;
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--card-bg);
    box-shadow: var(--card-shadow);
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .gallery-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--card-shadow-hover);
  }

  .gallery-item img {
    width: 100%;
    display: block;
  }

  .gallery-caption {
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    text-align: center;
  }

  .gallery-load-more {
    text-align: center;
    margin-top: 2rem;
  }

  .load-more-btn {
    padding: 0.625rem 2rem;
    border: 1px solid var(--border-color, #e5e5e5);
    border-radius: 0.5rem;
    background: var(--card-bg);
    color: var(--text-primary);
    font-size: 0.9375rem;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .load-more-btn:hover {
    background: var(--bg-tertiary);
    border-color: var(--link-color);
    color: var(--link-color);
  }

  /* Responsive columns */
  @media (max-width: 1024px) {
    .gallery-masonry {
      columns: 2;
    }
  }

  @media (max-width: 640px) {
    .gallery-page {
      padding: 1rem 0.75rem;
    }

    .gallery-masonry {
      columns: 1;
    }
  }
</style>
