---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Comment from '../../components/Comment.astro';
import { siteConfig } from '../../config';
import { loadFriends, loadFriendsChecked } from '../../utils/data';
import { t } from '../../utils/i18n';

const checked = loadFriendsChecked();
const aliveList = checked?.alive ?? loadFriends();
const deadList = checked?.dead ?? [];
---

<BaseLayout title={t('tabs.friends')} description={`${siteConfig.title} - ${t('tabs.friends')}`}>
  <div class="friends-page">
    <h1 class="page-title">{t('tabs.friends')}</h1>

    <div class="card-grid">
      {aliveList.map((friend) => (
        <a href={friend.url} target="_blank" rel="noopener noreferrer" class="card friend-card">
          <div class="card-body">
            <div class="friend-header">
              {friend.icon ? (
                <img src={friend.icon} alt={friend.name} class="card-avatar" loading="lazy" />
              ) : (
                <div class="card-icon"><span>{friend.name.charAt(0)}</span></div>
              )}
              <div class="friend-info">
                <h2 class="card-title">{friend.name}</h2>
                {friend.description && <p class="card-description">{friend.description}</p>}
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

    {deadList.length > 0 && (
      <>
        <hr class="cemetery-divider" />
        <h3 class="cemetery-title">
          <i class="fas fa-cross"></i> 数字墓园
          <span class="cemetery-subtitle">— 那些沉睡的站点</span>
        </h3>
        <div class="card-grid card-grid--dimmed">
          {deadList.map((friend) => (
            <a href={friend.url} target="_blank" rel="noopener noreferrer" class="card friend-card card-dead">
              <div class="card-body">
                <div class="friend-header">
                  <i class="fas fa-skull fa-2x text-muted flex-shrink-0"></i>
                  <div class="friend-info">
                    <h2 class="card-title">{friend.name}</h2>
                    {friend.description && <p class="card-description">{friend.description}</p>}
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
  <Comment />
</BaseLayout>

<style>
  .friends-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }

  .friend-card {
    text-decoration: none;
    color: inherit;
    display: block;
    cursor: pointer;
  }

  .friend-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .friend-info { min-width: 0; }

  .friend-card .card-title { margin-bottom: 0.25rem; }

  .friend-card .card-description {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cemetery-divider { margin: 2.5rem 0 1.5rem; border-color: var(--border-color); }

  .cemetery-title {
    color: var(--text-muted);
    font-size: 1.125rem;
    margin-bottom: 1.25rem;
  }

  .cemetery-title i { margin-right: 0.5rem; }

  .cemetery-subtitle {
    font-size: 0.875rem;
    font-weight: 400;
    margin-left: 0.5rem;
  }

  .card-grid--dimmed { opacity: 0.6; }

  .card-dead {
    border-style: dashed;
  }

  @media (max-width: 768px) {
    .friends-page { padding: 1rem 0.75rem; }
  }
</style>
