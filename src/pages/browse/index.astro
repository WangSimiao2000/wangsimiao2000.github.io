---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config';
import { getAllPosts, sortPosts, getCategories, getTags } from '../../utils/posts';
import { t } from '../../utils/i18n';
import type { Locale } from '../../types';

const locale = siteConfig.lang as Locale;
const allPosts = await getAllPosts();
const sorted = sortPosts(allPosts);

// Categories with sub-categories
const categoryMap = getCategories(allPosts);
const sortedCategories = [...categoryMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));

// Tags sorted alphabetically
const tagMap = getTags(allPosts);
const sortedTags = [...tagMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<BaseLayout title={t('tabs.browse')} description={`${siteConfig.title} - ${t('tabs.browse')}`}>
  <div class="browse-page">
    <h1 class="page-title">{t('tabs.browse')}</h1>

    <div class="browse-tabs">
      <button class="browse-tab active" data-target="browse-categories" aria-pressed="true">
        <i class="fas fa-stream"></i>
        {t('layout.category', locale)}
      </button>
      <button class="browse-tab" data-target="browse-tags" aria-pressed="false">
        <i class="fas fa-tags"></i>
        {t('layout.tag', locale)}
      </button>
    </div>

    <!-- Categories View -->
    <div id="browse-categories" class="browse-panel">
      {sortedCategories.map(([name, count]) => (
        <div class="card category-card">
          <div class="category-header">
            <span>
              <i class="far fa-folder fa-fw"></i>
              <a href={`/browse/categories/${name}/`} class="category-name">{name}</a>
              <span class="text-muted count">
                {count} {locale === 'zh-CN' ? '篇文章' : count === 1 ? 'post' : 'posts'}
              </span>
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- Tags View -->
    <div id="browse-tags" class="browse-panel" style="display:none;">
      <div class="tags-cloud">
        {sortedTags.map(([tag, count]) => (
          <a class="tag" href={`/browse/tags/${encodeURIComponent(tag)}/`}>
            {tag} <span class="text-muted">{count}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('click', (e) => {
    const tab = (e.target as HTMLElement).closest('.browse-tab') as HTMLElement | null;
    if (!tab) return;
    document.querySelectorAll('.browse-tab').forEach(t => {
      t.classList.remove('active');
      t.setAttribute('aria-pressed', 'false');
    });
    document.querySelectorAll('.browse-panel').forEach(p => {
      (p as HTMLElement).style.display = 'none';
    });
    tab.classList.add('active');
    tab.setAttribute('aria-pressed', 'true');
    const target = document.getElementById(tab.dataset.target!);
    if (target) target.style.display = 'block';
  });
</script>

<style>
  .browse-page {
    padding: 2rem 1rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
  }

  .browse-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .browse-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: 0.5rem;
    background: var(--bg-secondary);
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 0.9375rem;
    transition: all 0.2s;
  }

  .browse-tab.active {
    background: var(--btn-primary-bg);
    color: var(--btn-primary-text);
    border-color: var(--btn-primary-bg);
  }

  .category-card {
    margin-bottom: 0.5rem;
  }

  .category-header {
    padding: 0.75rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .category-header i { margin-right: 0.5rem; color: var(--text-muted); }

  .category-name {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    margin-right: 0.5rem;
  }

  .category-name:hover { color: var(--link-color); }

  .count { font-size: 0.8125rem; }

  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  @media (max-width: 768px) {
    .browse-page { padding: 1rem 0.75rem; }
  }
</style>
