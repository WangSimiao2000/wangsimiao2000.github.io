---
/**
 * 标签浏览页 - 按标签筛选文章列表
 *
 * URL: /browse/tags/{name}/
 * 使用 getStaticPaths 为每个标签生成路由
 *
 * Requirements: 3.1
 */
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../config';
import { sortPosts, getTags, getPostsByTag, getPostUrl } from '../../../utils/posts';
import { formatDate } from '../../../utils/date';
import { t } from '../../../utils/i18n';
import type { Locale } from '../../../types';

export const getStaticPaths: GetStaticPaths = async () => {
  const allPosts = await getCollection('posts');
  const tags = getTags(allPosts);

  return [...tags.keys()].map((name) => ({
    params: { name },
  }));
};

const locale = siteConfig.lang as Locale;
const { name } = Astro.params;

const allPosts = await getCollection('posts');
const sortedAll = sortPosts(allPosts);
const tagPosts = getPostsByTag(sortedAll, name!);
---

<BaseLayout
  title={`${t('layout.tag')}: ${name}`}
  description={`${siteConfig.title} - ${t('layout.tag')}: ${name}`}
>
  <div class="browse-page">
    <header class="browse-header">
      <span class="browse-label">{t('layout.tag')}</span>
      <h1 class="browse-name">{name}</h1>
      <p class="browse-count">
        {tagPosts.length} {locale === 'zh-CN' ? '篇文章' : tagPosts.length === 1 ? 'post' : 'posts'}
      </p>
    </header>

    <ul class="post-list">
      {tagPosts.map((post) => (
        <li class="post-item">
          <time datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date, locale)}
          </time>
          <a href={getPostUrl(post.slug)}>{post.data.title}</a>
        </li>
      ))}
    </ul>

    {tagPosts.length === 0 && (
      <p class="no-posts">{locale === 'zh-CN' ? '该标签下暂无文章' : 'No posts with this tag'}</p>
    )}
  </div>
</BaseLayout>

<style>
  .browse-page {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .browse-header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .browse-label {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .browse-name {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .browse-count {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border-color, #e5e5e5);
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-item time {
    flex-shrink: 0;
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    min-width: 5.5rem;
  }

  .post-item a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .post-item a:hover {
    color: var(--link-color);
  }

  .no-posts {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
  }

  @media (max-width: 768px) {
    .browse-page {
      padding: 1rem 0.75rem;
    }

    .post-item {
      flex-direction: column;
      gap: 0.125rem;
    }

    .post-item time {
      min-width: auto;
    }
  }
</style>
