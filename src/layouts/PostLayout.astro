---
/**
 * PostLayout - 文章详情布局
 *
 * 包含:
 * - 文章标题
 * - 元信息（日期、分类、标签、阅读时间）
 * - 当 Frontmatter 包含 last_modified_at 时同时显示发布日期和最后修改日期
 * - TOC（目录）
 * - 文章内容
 * - CodeCopy（代码复制按钮）
 * - 前后导航 (PostNav)
 * - 相关文章 (RelatedPosts)
 * - 评论区
 * - JSON-LD 结构化数据
 *
 * Requirements: 2.4, 3.3, 3.4, 10.5
 */
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';
import CodeCopy from '../components/CodeCopy.astro';
import PostNav from '../components/PostNav.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import Comment from '../components/Comment.astro';
import { siteConfig } from '../config';
import { formatDate } from '../utils/date';
import { calculateReadingTime } from '../utils/reading-time';
import { extractHeadings } from '../utils/toc';
import { generateJsonLd } from '../utils/seo';
import { t } from '../utils/i18n';
import type { Locale } from '../types';
import type { Post } from '../utils/posts';

interface Props {
  title: string;
  date: Date;
  categories?: string[];
  tags?: string[];
  description?: string;
  image?: string;
  lastModifiedAt?: Date;
  comments?: boolean;
  toc?: boolean;
  content?: string;
  slug?: string;
  prev?: Post | null;
  next?: Post | null;
  relatedPosts?: Post[];
}

const {
  title,
  date,
  categories = [],
  tags = [],
  description = '',
  image,
  lastModifiedAt,
  comments = true,
  toc = siteConfig.toc,
  content = '',
  slug = '',
  prev = null,
  next = null,
  relatedPosts = [],
} = Astro.props;

const locale = siteConfig.lang as Locale;
const formattedDate = formatDate(date, locale);
const formattedModified = lastModifiedAt ? formatDate(lastModifiedAt, locale) : null;
const readingTime = calculateReadingTime(content, locale);
const postUrl = new URL(`/posts/${slug}/`, siteConfig.url).href;

// Extract headings for TOC
const headings = toc ? extractHeadings(content) : [];

// Generate JSON-LD structured data
const jsonLdHtml = generateJsonLd({
  title,
  author: siteConfig.social.name,
  date,
  description: description || undefined,
  url: postUrl,
  image: image ? new URL(image, siteConfig.url).href : undefined,
  lastModified: lastModifiedAt,
});
---

<BaseLayout title={title} description={description} ogImage={image}>
  <!-- JSON-LD structured data -->
  <Fragment set:html={jsonLdHtml} slot="head" />

  <article class="post-content">
    <!-- Post header -->
    <header class="post-header">
      <h1 class="post-title">{title}</h1>

      <div class="post-meta">
        <!-- Dates -->
        <span class="post-date">
          <span class="post-date-label">{t('post.posted', locale)}</span>
          <time datetime={date.toISOString()}>{formattedDate}</time>
        </span>

        {formattedModified && (
          <span class="post-updated">
            <span class="post-updated-label">{t('post.updated', locale)}</span>
            <time datetime={lastModifiedAt!.toISOString()}>{formattedModified}</time>
          </span>
        )}

        <!-- Reading time -->
        <span class="post-reading-time">
          {readingTime.minutes} {t('post.read_time.unit', locale)}
        </span>

        <!-- Categories -->
        {categories.length > 0 && (
          <span class="post-categories">
            {categories.map((cat) => (
              <a href={`/browse/categories/${cat}/`} class="post-category">{cat}</a>
            ))}
          </span>
        )}

        <!-- Tags -->
        {tags.length > 0 && (
          <span class="post-tags">
            {tags.map((tag) => (
              <a href={`/browse/tags/${tag}/`} class="post-tag">#{tag}</a>
            ))}
          </span>
        )}
      </div>
    </header>

    <!-- TOC -->
    {toc && headings.length > 0 && (
      <TOC headings={headings} />
    )}

    <!-- Post body -->
    <div class="post-body">
      <slot />
    </div>

    <!-- Code copy buttons -->
    <CodeCopy />

    <!-- Post navigation -->
    <PostNav prev={prev} next={next} />

    <!-- Related posts -->
    <RelatedPosts posts={relatedPosts} />

    <!-- Comment section -->
    <Comment enabled={comments} />
  </article>
</BaseLayout>

<style>
  .post-content {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 1rem;
    color: var(--text-primary);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .post-date-label,
  .post-updated-label {
    margin-right: 0.25rem;
  }

  .post-updated {
    font-style: italic;
  }

  .post-categories {
    display: flex;
    gap: 0.375rem;
  }

  .post-category {
    color: var(--link-color);
    text-decoration: none;
  }

  .post-category:hover {
    text-decoration: underline;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .post-tag {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.8125rem;
  }

  .post-tag:hover {
    color: var(--link-color);
  }

  .post-body {
    line-height: 1.75;
    color: var(--text-primary);
  }

  .giscus-container {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color, #e5e5e5);
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 1.5rem;
    }

    .post-content {
      padding: 1rem 0.75rem;
    }
  }
</style>
