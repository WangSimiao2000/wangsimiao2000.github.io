---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';
import CodeCopy from '../components/CodeCopy.astro';
import PostNav from '../components/PostNav.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import Comment from '../components/Comment.astro';
import { siteConfig } from '../config';
import { formatDate } from '../utils/date';
import { calculateReadingTime } from '../utils/reading-time';
import { extractHeadings } from '../utils/toc';
import { generateJsonLd } from '../utils/seo';
import { t } from '../utils/i18n';
import type { Locale } from '../types';
import type { Post } from '../utils/posts';

interface Props {
  title: string;
  date: Date;
  categories?: string[];
  tags?: string[];
  description?: string;
  image?: string;
  lastModifiedAt?: Date;
  comments?: boolean;
  toc?: boolean;
  content?: string;
  slug?: string;
  prev?: Post | null;
  next?: Post | null;
  relatedPosts?: Post[];
}

const {
  title, date, categories = [], tags = [], description = '',
  image, lastModifiedAt, comments = true, toc = siteConfig.toc,
  content = '', slug = '', prev = null, next = null, relatedPosts = [],
} = Astro.props;

const locale = siteConfig.lang as Locale;
const formattedDate = formatDate(date, locale);
const formattedModified = lastModifiedAt ? formatDate(lastModifiedAt, locale) : null;
const readingTime = calculateReadingTime(content, locale);
const postUrl = new URL(`/posts/${slug}/`, siteConfig.url).href;
const headings = toc ? extractHeadings(content) : [];
const jsonLdHtml = generateJsonLd({
  title, author: siteConfig.social.name, date,
  description: description || undefined, url: postUrl,
  image: image ? new URL(image, siteConfig.url).href : undefined,
  lastModified: lastModifiedAt,
});

const licenseTemplate = t('copyright.license.template', locale);
const licenseName = t('copyright.license.name', locale);
const licenseLink = t('copyright.license.link', locale);
---

<BaseLayout title={title} description={description} ogImage={image}>
  <Fragment set:html={jsonLdHtml} slot="head" />

  <div class="post-layout">
    <article class="post-content">
      <header class="post-header">
        <h1 class="post-title">{title}</h1>
        <div class="post-meta">
          <span class="post-date">
            <span class="post-date-label">{t('post.posted', locale)}</span>
            <time datetime={date.toISOString()}>{formattedDate}</time>
          </span>
          {formattedModified && (
            <span class="post-updated">
              <span class="post-updated-label">{t('post.updated', locale)}</span>
              <time datetime={lastModifiedAt!.toISOString()}>{formattedModified}</time>
            </span>
          )}
          <span class="post-reading-time">
            {readingTime.minutes} {t('post.read_time.unit', locale)}
          </span>
          {categories.length > 0 && (
            <span class="post-categories">
              {categories.map((cat) => (
                <a href={`/browse/categories/${cat}/`} class="post-category">{cat}</a>
              ))}
            </span>
          )}
          {tags.length > 0 && (
            <span class="post-tags">
              {tags.map((tag) => (
                <a href={`/browse/tags/${tag}/`} class="post-tag">#{tag}</a>
              ))}
            </span>
          )}
        </div>
      </header>

      <div class="post-body">
        <slot />
      </div>

      <CodeCopy />

      <!-- Copyright -->
      <footer class="post-copyright">
        <p set:html={licenseTemplate.replace(':LICENSE_NAME', `<a href="${licenseLink}" target="_blank" rel="noopener">${licenseName}</a>`)} />
      </footer>

      <PostNav prev={prev} next={next} />
      <RelatedPosts posts={relatedPosts} />
      <Comment enabled={comments} />
    </article>

    {toc && headings.length > 0 && (
      <aside class="toc-sidebar">
        <TOC headings={headings} />
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .post-layout {
    display: flex;
    gap: 2rem;
    max-width: 64rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .post-content { flex: 1; min-width: 0; }

  .toc-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: relative;
  }

  .post-header { margin-bottom: 2rem; }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 1rem;
    color: var(--text-primary);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .post-date-label, .post-updated-label { margin-right: 0.25rem; }
  .post-updated { font-style: italic; }

  .post-categories { display: flex; gap: 0.375rem; }
  .post-category { color: var(--link-color); text-decoration: none; }
  .post-category:hover { text-decoration: underline; }

  .post-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  .post-tag { color: var(--text-muted); text-decoration: none; font-size: 0.8125rem; }
  .post-tag:hover { color: var(--link-color); }

  .post-body { line-height: 1.75; color: var(--text-primary); }

  .post-copyright {
    margin-top: 2rem;
    padding: 1rem;
    background: var(--bg-tertiary);
    border-radius: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    border-left: 3px solid var(--btn-primary-bg);
  }

  .post-copyright p { margin: 0; }
  .post-copyright :global(a) { color: var(--link-color); }

  @media (max-width: 1200px) {
    .toc-sidebar { display: none; }
  }

  @media (max-width: 768px) {
    .post-title { font-size: 1.5rem; }
    .post-layout { padding: 1rem 0.75rem; }
  }
</style>
