---
/**
 * BaseLayout - 基础布局组件
 *
 * 负责:
 * - <head> 标签（SEO meta、Open Graph、JSON-LD、KaTeX CSS）
 * - ViewTransitions 客户端路由
 * - Sidebar（transition:persist）
 * - Topbar（transition:persist）
 * - <main id="swup"> 内容容器（fade 过渡动画）
 * - 全局样式引入
 * - astro:after-swap / astro:page-load 事件监听
 *
 * Requirements: 3.8, 3.9, 3.10, 3.11, 3.12, 10.1
 */
import { ClientRouter } from 'astro:transitions';
import { siteConfig } from '../config';
import { shouldEnablePWA } from '../utils/pwa';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
import SearchModal from '../components/SearchModal.astro';
import PWAUpdateNotification from '../components/PWAUpdateNotification.astro';
import '../styles/global.css';

const pwaEnabled = shouldEnablePWA(siteConfig);

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = siteConfig.description,
  ogImage,
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href;
const pageTitle = title === siteConfig.title
  ? siteConfig.title
  : `${title} | ${siteConfig.title}`;
const ogImageUrl = ogImage
  ? new URL(ogImage, siteConfig.url).href
  : undefined;
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.title} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- Search Engine Verification -->
    {siteConfig.seo.google && (
      <meta name="google-site-verification" content={siteConfig.seo.google} />
    )}
    {siteConfig.seo.bing && (
      <meta name="msvalidate.01" content={siteConfig.seo.bing} />
    )}

    <!-- KaTeX CSS for math rendering -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+"
      crossorigin="anonymous"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/assets/img/avatar/avatar.png" />

    <!-- Client Router (View Transitions) -->
    <ClientRouter />

    <!-- Busuanzi visitor counter -->
    <script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
  </head>

  <body>
    <!-- Skip to content link (accessibility) -->
    <a href="#swup" class="skip-link">跳到主要内容</a>

    <div class="site-wrapper">
      <Sidebar />

      <div id="main-wrapper" class="main-wrapper">
        <Topbar />

        <!-- Main content area with fade transition -->
        <main id="swup" class="content-wrapper" transition:animate="fade">
          <slot />
        </main>

        <!-- Footer -->
        <footer class="site-footer" aria-label="Site Info">
          <p>© <time>{new Date().getFullYear()}</time> <a href={siteConfig.url}>{siteConfig.social.name}</a></p>
          <p class="busuanzi-stats">
            <span id="busuanzi_container_site_pv">
              本站总浏览量 <span id="busuanzi_value_site_pv"><i class="fas fa-spinner fa-spin"></i></span> 次
            </span>
            &nbsp;|&nbsp;
            <span id="busuanzi_container_site_uv">
              总访客数 <span id="busuanzi_value_site_uv"><i class="fas fa-spinner fa-spin"></i></span> 人
            </span>
          </p>
          <p class="site-credit">
            基于 <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> 构建，
            灵感来自 <a href="https://github.com/cotes2020/jekyll-theme-chirpy" target="_blank" rel="noopener">Chirpy</a> 主题
          </p>
        </footer>
      </div>
    </div>

    <!-- Search Modal (client:load) -->
    <SearchModal />

    <!-- PWA Update Notification (conditional on siteConfig.pwa.enabled) -->
    {pwaEnabled && <PWAUpdateNotification />}

    <!-- Page transition & component re-initialization scripts -->
    <script>
      /**
       * Re-initialize page-specific components after View Transitions swap.
       * Requirement 3.11: TOC, CodeCopy, Lightbox, Mermaid re-init after page swap.
       */
      document.addEventListener('astro:after-swap', () => {
        // Re-initialize TOC scroll highlighting
        if (typeof window.initTOC === 'function') {
          window.initTOC();
        }

        // Re-initialize code copy buttons
        if (typeof window.initCodeCopy === 'function') {
          window.initCodeCopy();
        }

        // Re-initialize lightbox for gallery images
        if (typeof window.initLightbox === 'function') {
          window.initLightbox();
        }

        // Re-render Mermaid diagrams
        if (typeof window.renderMermaid === 'function') {
          window.renderMermaid();
        }
      });

      /**
       * Update sidebar active state after page load.
       * Requirement 3.12: Sidebar nav active state reflects current page.
       */
      document.addEventListener('astro:page-load', () => {
        updateSidebarActiveState();
      });

      function updateSidebarActiveState(): void {
        const currentPath = window.location.pathname;
        const navLinks = document.querySelectorAll('#sidebar .sidebar-nav a');

        navLinks.forEach((link) => {
          const anchor = link as HTMLAnchorElement;
          const href = anchor.getAttribute('href') || '';

          // Remove existing active class
          anchor.classList.remove('active');

          // Match exact path or path prefix for sub-pages
          if (href === '/' && currentPath === '/') {
            anchor.classList.add('active');
          } else if (href !== '/' && currentPath.startsWith(href)) {
            anchor.classList.add('active');
          }
        });
      }
    </script>
  </body>
</html>

<style>
  .site-footer {
    text-align: center;
    padding: 1.5rem 1rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    border-top: 1px solid var(--border-color);
    margin-top: 2rem;
  }

  .site-footer p { margin: 0.25rem 0; }
  .site-footer a { color: var(--link-color); text-decoration: none; }
  .site-footer a:hover { text-decoration: underline; }

  .busuanzi-stats { font-size: 0.75rem; }

  .site-credit { font-size: 0.75rem; opacity: 0.8; }

  /* Responsive: hide sidebar on mobile */
  @media (max-width: 768px) {
    .site-wrapper {
      flex-direction: column;
    }
  }
</style>
