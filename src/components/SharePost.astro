---
/**
 * SharePost - 文章分享组件
 *
 * 从 data/share.yml 读取分享平台配置，生成分享链接
 *
 * Requirements: 4.6
 */
import { t } from '../utils/i18n';
import { loadShare } from '../utils/data';
import { generateShareLinks } from '../utils/share';

interface Props {
  /** Full URL of the post */
  postUrl: string;
  /** Title of the post */
  postTitle: string;
}

const { postUrl, postTitle } = Astro.props;

const shareData = loadShare();
const shareLinks = generateShareLinks(shareData.platforms, postUrl, postTitle);
const shareLabel = t('post.share') || '分享';
---

{shareLinks.length > 0 && (
  <div class="share-post">
    <span class="share-label">{shareLabel}</span>
    <div class="share-links">
      {shareLinks.map((link) => (
        <a
          href={link.url}
          class="share-link"
          target="_blank"
          rel="noopener noreferrer"
          title={link.type}
          aria-label={`${shareLabel} ${link.type}`}
        >
          <i class={link.icon} aria-hidden="true"></i>
        </a>
      ))}
    </div>
  </div>
)}

<style>
  .share-post {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
  }

  .share-label {
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .share-links {
    display: flex;
    gap: 0.5rem;
  }

  .share-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .share-link:hover {
    color: var(--text-primary);
    background: var(--tag-bg);
  }
</style>
