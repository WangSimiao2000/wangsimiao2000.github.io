---
/**
 * RelatedPosts - 相关文章推荐
 *
 * Requirements: 3.4
 */
import { t } from '../utils/i18n';
import { getPostUrl } from '../utils/posts';
import { formatDate } from '../utils/date';
import { siteConfig } from '../config';
import type { Post } from '../utils/posts';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
const title = t('post.relate_posts') || '相关文章';
---

{posts.length > 0 && (
  <section class="related-posts">
    <h2 class="related-title">{title}</h2>
    <ul class="related-list">
      {posts.map((post) => (
        <li class="related-item">
          <a href={getPostUrl(post.slug)}>
            <span class="related-post-title">{post.data.title}</span>
            <time class="related-date" datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date, siteConfig.lang)}
            </time>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .related-posts {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
  }

  .related-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .related-item {
    margin: 0;
  }

  .related-item a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.5rem 0;
    text-decoration: none;
    border-bottom: 1px solid var(--border-color);
    transition: background-color 0.2s ease;
  }

  .related-item:last-child a {
    border-bottom: none;
  }

  .related-item a:hover {
    background: var(--tag-bg);
    margin: 0 -0.5rem;
    padding: 0.5rem;
    border-radius: 0.375rem;
    border-bottom-color: transparent;
  }

  .related-post-title {
    color: var(--link-color);
    font-size: 0.9375rem;
    line-height: 1.4;
  }

  .related-date {
    color: var(--text-muted);
    font-size: 0.8125rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
