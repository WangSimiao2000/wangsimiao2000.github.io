---
/**
 * Sidebar - 侧边栏组件
 *
 * 包含头像、站点标题、导航菜单、社交链接
 * 社交链接从 data/contact.yml 读取
 *
 * Requirements: 4.1, 12.4
 */
import { siteConfig } from '../config';
import { loadContact } from '../utils/data';
import { t } from '../utils/i18n';
import ThemeToggle from './ThemeToggle.astro';

const contacts = loadContact();

const navItems = [
  { href: '/', label: t('tabs.home'), icon: 'fas fa-home' },
  { href: '/archives/', label: t('tabs.archives'), icon: 'fas fa-archive' },
  { href: '/friends/', label: t('tabs.friends'), icon: 'fas fa-user-friends' },
  { href: '/gallery/', label: t('tabs.gallery'), icon: 'fas fa-images' },
  { href: '/tools/', label: t('tabs.tools'), icon: 'fas fa-tools' },
  { href: '/about/', label: t('tabs.about'), icon: 'fas fa-info-circle' },
];
---

<aside id="sidebar" class="sidebar" transition:persist>
  <div class="sidebar-inner">
    <!-- Avatar & Title -->
    <a href="/" class="sidebar-profile">
      <img
        src={siteConfig.avatar}
        alt={siteConfig.title}
        class="sidebar-avatar"
        width="112"
        height="112"
        loading="eager"
      />
    </a>
    <h1 class="sidebar-title">{siteConfig.title}</h1>
    <p class="sidebar-tagline">{siteConfig.tagline}</p>

    <!-- Navigation -->
    <nav class="sidebar-nav" aria-label="主导航">
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href}>
              <i class={item.icon} aria-hidden="true"></i>
              <span>{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Bottom section: social links + theme toggle -->
    <div class="sidebar-bottom">
      <div class="sidebar-social" aria-label="社交链接">
        {contacts.map((contact) => {
          const href = contact.url
            ? contact.url
            : contact.type === 'email'
              ? `mailto:${siteConfig.social.email}`
              : contact.type === 'rss'
                ? '/feed.xml'
                : contact.type === 'github'
                  ? `https://github.com/${siteConfig.social.github}`
                  : '#';
          return (
            <a
              href={href}
              class="social-link"
              title={contact.type}
              target={contact.noblank ? undefined : '_blank'}
              rel={contact.noblank ? undefined : 'noopener noreferrer'}
              aria-label={contact.type}
            >
              <i class={contact.icon} aria-hidden="true"></i>
            </a>
          );
        })}
      </div>
      <ThemeToggle />
    </div>
  </div>
</aside>

<style>
  .sidebar {
    width: 260px;
    min-height: 100vh;
    background: var(--sidebar-bg);
    color: var(--sidebar-text);
    padding: 2rem 1.25rem;
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    height: 100%;
  }

  .sidebar-profile {
    text-decoration: none;
  }

  .sidebar-avatar {
    width: 112px;
    height: 112px;
    border-radius: 50%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .sidebar-avatar:hover {
    transform: scale(1.05);
  }

  .sidebar-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    color: var(--sidebar-text);
  }

  .sidebar-tagline {
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-align: center;
    margin: 0;
    line-height: 1.4;
  }

  .sidebar-nav {
    width: 100%;
    margin-top: 0.5rem;
  }

  .sidebar-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-nav li {
    margin: 0;
  }

  .sidebar-nav a {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    color: var(--sidebar-text);
    text-decoration: none;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    transition: background-color 0.2s ease;
  }

  .sidebar-nav a:hover {
    background: var(--sidebar-hover-bg);
  }

  .sidebar-nav a :global(.active) {
    background: var(--sidebar-active);
    color: #fff;
  }

  .sidebar-nav i {
    width: 1.25rem;
    text-align: center;
    font-size: 0.875rem;
  }

  .sidebar-bottom {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    width: 100%;
  }

  .sidebar-social {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: var(--sidebar-text);
    opacity: 0.7;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: opacity 0.2s ease, background-color 0.2s ease;
  }

  .social-link:hover {
    opacity: 1;
    background: var(--sidebar-hover-bg);
  }

  /* Responsive: hide sidebar on mobile */
  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }
  }
</style>
