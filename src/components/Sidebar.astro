---
import { siteConfig } from '../config';
import { loadContact } from '../utils/data';
import { t } from '../utils/i18n';
import ThemeToggle from './ThemeToggle.astro';

const contacts = loadContact();

const navItems = [
  { href: '/', label: t('tabs.home'), icon: 'fas fa-home' },
  { href: '/browse/', label: t('tabs.browse'), icon: 'fas fa-stream' },
  { href: '/archives/', label: t('tabs.archives'), icon: 'fas fa-archive' },
  { href: '/friends/', label: t('tabs.friends'), icon: 'fas fa-user-friends' },
  { href: '/gallery/', label: t('tabs.gallery'), icon: 'fas fa-images' },
  { href: '/tools/', label: t('tabs.tools'), icon: 'fas fa-tools' },
  { href: '/about/', label: t('tabs.about'), icon: 'fas fa-info-circle' },
];
---

<aside id="sidebar" class="sidebar" transition:persist>
  <div class="sidebar-inner">
    <a href="/" class="sidebar-profile">
      <img src={siteConfig.avatar} alt={siteConfig.title} class="sidebar-avatar" width="112" height="112" loading="eager" />
    </a>
    <h1 class="sidebar-title">{siteConfig.title}</h1>
    <p class="sidebar-tagline">{siteConfig.tagline}</p>

    <nav class="sidebar-nav" aria-label="主导航">
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href}>
              <i class={item.icon} aria-hidden="true"></i>
              <span>{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="sidebar-bottom">
      <ThemeToggle />
      {contacts.map((contact) => {
        const isWechat = contact.type === 'wechat';
        const isQQ = contact.type === 'qq';
        const href = contact.url
          ? contact.url
          : contact.type === 'email'
            ? `mailto:${siteConfig.social.email}`
            : contact.type === 'rss'
              ? '/feed.xml'
              : contact.type === 'github'
                ? `https://github.com/${siteConfig.social.github}`
                : '#';
        return (
          <a
            href={isWechat || isQQ ? 'javascript:void(0)' : href}
            class="social-link"
            title={contact.type}
            target={contact.noblank || isWechat || isQQ ? undefined : '_blank'}
            rel={contact.noblank || isWechat || isQQ ? undefined : 'noopener noreferrer'}
            aria-label={contact.type}
            data-modal={isWechat ? 'wechat-modal' : isQQ ? 'qq-modal' : undefined}
          >
            <i class={contact.icon} aria-hidden="true"></i>
          </a>
        );
      })}
    </div>
  </div>
</aside>

<!-- WeChat QR Modal -->
<div id="wechat-modal" class="qr-modal" style="display:none;">
  <div class="qr-modal-inner">
    <img src="https://cdn.mickeymiao.cn/assets/img/wechat-qr.png" alt="微信二维码" />
    <p>微信扫码添加好友</p>
  </div>
</div>

<!-- QQ QR Modal -->
<div id="qq-modal" class="qr-modal" style="display:none;">
  <div class="qr-modal-inner">
    <img src="https://cdn.mickeymiao.cn/assets/img/qq-qr.png" alt="QQ二维码" />
    <p>QQ 扫码添加好友</p>
  </div>
</div>

<script>
  // QR modal open/close
  document.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('[data-modal]') as HTMLElement | null;
    if (link) {
      e.preventDefault();
      const modal = document.getElementById(link.dataset.modal!);
      if (modal) modal.style.display = 'flex';
      return;
    }
    const modal = (e.target as HTMLElement).closest('.qr-modal') as HTMLElement | null;
    if (modal && !(e.target as HTMLElement).closest('.qr-modal-inner')) {
      modal.style.display = 'none';
    }
  });
</script>

<style>
  .sidebar {
    width: 260px;
    min-height: 100vh;
    background: var(--sidebar-bg);
    color: var(--sidebar-text, var(--text-primary));
    padding: 2rem 1.25rem;
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    height: 100%;
  }

  .sidebar-profile { text-decoration: none; }

  .sidebar-avatar {
    width: 112px;
    height: 112px;
    border-radius: 50%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .sidebar-avatar:hover { transform: scale(1.05); }

  .sidebar-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    color: var(--sidebar-text, var(--text-primary));
  }

  .sidebar-tagline {
    font-size: 0.8125rem;
    color: var(--sidebar-muted-color, var(--text-muted));
    text-align: center;
    margin: 0;
    line-height: 1.4;
  }

  .sidebar-nav { width: 100%; margin-top: 0.5rem; }
  .sidebar-nav ul { list-style: none; padding: 0; margin: 0; }

  .sidebar-nav a {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    color: var(--sidebar-text, var(--text-primary));
    text-decoration: none;
    border-radius: 0.75rem;
    font-size: 0.9375rem;
    font-weight: 600;
    transition: background-color 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      padding-left 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
      color 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sidebar-nav a:hover {
    background: var(--sidebar-hover-bg);
    padding-left: 1.25rem;
  }

  .sidebar-nav a.active {
    background: var(--sidebar-active);
    color: #fff;
  }

  .sidebar-nav i {
    width: 1.25rem;
    text-align: center;
    font-size: 0.875rem;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .sidebar-nav a:hover i { transform: scale(1.15); }

  .sidebar-bottom {
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding-top: 1rem;
    width: 100%;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: var(--sidebar-text, var(--text-primary));
    opacity: 0.7;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: opacity 0.2s ease, background-color 0.2s ease;
  }

  .social-link:hover {
    opacity: 1;
    background: var(--sidebar-hover-bg);
  }

  /* QR Modals */
  .qr-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(0,0,0,0.6);
    justify-content: center;
    align-items: center;
    cursor: pointer;
  }

  .qr-modal-inner {
    background: #fff;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    max-width: 280px;
    cursor: default;
  }

  .qr-modal-inner img {
    width: 220px;
    height: 220px;
    border-radius: 6px;
  }

  .qr-modal-inner p {
    margin: 0.8rem 0 0;
    font-size: 0.85rem;
    color: #666;
  }

  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      left: 0;
      top: 0;
      z-index: 1000;
      transform: translateX(-100%);
      transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
      width: 260px;
    }

    .sidebar.open {
      transform: translateX(0);
    }
  }
</style>
